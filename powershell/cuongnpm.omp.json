{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "os": "#ACB0BE",
    "closer": "p:os",
    "pink": "#ea76cb",
    "lavender": "#7287FD",
    "blue": "#1e66f5"
  },
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "properties": {
            "style": "full"
          },
          "style": "powerline",
          "template": " {{ .Path }} ",
          "foreground": "p:pink",
          "type": "path"
        },
        {
          "properties": {
            "fetch_package_manager": true,
            "npm_icon": " \ue71e ",
            "yarn_icon": " \ue6a7 "
          },
          "type": "node",
          "style": "powerline",
          "template": " \ue718 {{ if .PackageManagerIcon }}{{ .PackageManagerIcon }} {{ end }}{{ .Full }} ",
          "foreground": "#3C873A"
        },
        {
          "type": "dotnet",
          "style": "powerline",
          "foreground": "#9179E4",
          "template": "  {{ .Full }} "
        },
        {
          "foreground": "p:lavender",
          "properties": {
            "branch_icon": "\ue725 ",
            "cherry_pick_icon": "\ue29b ",
            "commit_icon": "\uf417 ",
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "merge_icon": "\ue727 ",
            "no_commits_icon": "\uf0c3 ",
            "rebase_icon": "\ue728 ",
            "revert_icon": "\uf0e2 ",
            "tag_icon": "\uf412 "
          },
          "template": " {{ .HEAD }} {{ if .Working.Changed }}{{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }}<#ef5350> \uf046 {{ .Staging.String }}</>{{ end }} ",
          "style": "powerline",
          "type": "git",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }} {{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }} {{ end }}",
            "{{ if gt .Ahead 0 }} {{ end }}",
            "{{ if gt .Behind 0 }} {{ end }}"
          ]
        }
      ],
      "type": "prompt"
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "style": "plain",
          "foreground": "#21c7c7",
          "type": "text"
        },
        {
          "properties": {
            "always_enabled": true
          },
          "style": "plain",
          "template": "{{ if gt .Code 0 }}\uf00d{{ else }}\uf42e{{ end }} ",
          "foreground": "#05c7f7",
          "type": "text",
          "foreground_templates": ["{{ if gt .Code 0 }}#ef5350{{ end }}"]
        }
      ],
      "newline": true
    }
  ],
  "final_space": true,
  "version": 3
}
